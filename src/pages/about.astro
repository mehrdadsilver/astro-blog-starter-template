	}
	.about-content h2 {
		margin-top: 2rem;
		font-size: 1.4rem;
		background: linear-gradient(135deg, var(--text-primary), var(--accent-light));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.about-content ul {
		padding-left: 1.2rem;
	}
	.about-content li {
		margin-bottom: 0.75rem;
		color: var(--text-secondary);
	}
	.about-content li strong {
		color: var(--text-primary);
	}
	.about-content p {
		color: var(--text-secondary);
		line-height: 1.8;
	}
	.connect-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}
	.connect-links a {
		padding: 0.5rem 1rem;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 8px;
		color: var(--accent-light);
		text-decoration: none;
		font-size: 0.85rem;
		font-weight: 600;
		transition: all 0.2s;
	}
	.connect-links a:hover {
		background: var(--bg-card-hover);
		border-color: var(--accent);
		color: var(--cyan);
	}
	.patent-card {
		display: flex;
		gap: 1.25rem;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1.5rem;
		margin-top: 1rem;
		position: relative;
		overflow: hidden;
	}
	.patent-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: linear-gradient(90deg, #fbbf24, #f59e0b, var(--accent));
	}
	.patent-icon {
		font-size: 2rem;
		line-height: 1;
		flex-shrink: 0;
	}
	.patent-number {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #fbbf24;
		font-weight: 600;
		margin-bottom: 0.3rem;
	}
	.patent-title {
		font-size: 1.15rem;
		color: var(--text-primary);
		margin: 0 0 0.6rem;
		line-height: 1.3;
	}
	.patent-abstract {
		font-size: 0.85rem;
		color: var(--text-secondary);
		line-height: 1.6;
		margin: 0 0 0.75rem;
	}
	.patent-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1.25rem;
		font-size: 0.72rem;
		color: var(--text-muted);
		margin-bottom: 0.4rem;
	}
	.patent-inventors {
		font-size: 0.72rem;
		color: var(--text-muted);
		margin-bottom: 0.75rem;
	}
	.patent-link {
		display: inline-block;
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--accent-light);
		text-decoration: none;
		transition: color 0.2s;
	}
	.patent-link:hover {
		color: var(--cyan);
	}
</style>
