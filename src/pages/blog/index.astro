---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { SITE_TITLE, CATEGORIES } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<SiteLayout title={`All Articles — ${SITE_TITLE}`} description="All articles by Mehrdad Abdolghafari">
	<div class="page-header">
		<h1>All Articles</h1>
		<p>{posts.length} articles across all categories</p>
	</div>

	<div class="cards-grid">
		{posts.map((post) => {
			const cat = CATEGORIES.find((c) => c.slug === post.data.category);
			return (
				<a href={`/blog/${post.id}`} class="card">
					<div class="card-category">{cat?.icon} {cat?.name}</div>
					<h3 class="card-title">{post.data.title}</h3>
					<p class="card-description">{post.data.description}</p>
					<div class="card-date"><FormattedDate date={post.data.pubDate} /></div>
				</a>
			);
		})}
	</div>
</SiteLayout>
